{
  "name": "gemma-it-ticket-webui",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "setup": "scripts/setup.sh",
    "local": "scripts/run_local.sh",
    "setup:windows": "powershell -ExecutionPolicy Bypass -File scripts/setup_windows.ps1",
    "local:windows": "powershell -ExecutionPolicy Bypass -File scripts/run_local_windows.ps1",
    "dev": "vite --host 127.0.0.1 --port 5173",
    "dev:api": "node --watch server.js",
    "build": "vite build",
    "index:knowledge": "node scripts/index_knowledge.js",
    "preview": "vite preview --host 127.0.0.1 --port 4173"
  },
  "dependencies": {
    "@react-three/drei": "latest",
    "@react-three/fiber": "latest",
    "dotenv": "latest",
    "express": "latest",
    "framer-motion": "latest",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "three": "latest"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@vitejs/plugin-react": "latest",
    "autoprefixer": "latest",
    "postcss": "latest",
    "tailwindcss": "latest",
    "vite": "latest"
  }
}
