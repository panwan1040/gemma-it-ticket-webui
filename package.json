{
  "name": "gemma-it-ticket-webui",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "setup": "scripts/setup.sh",
    "local": "scripts/run_local.sh",
    "setup:windows": "powershell -ExecutionPolicy Bypass -File scripts/setup_windows.ps1",
    "local:windows": "powershell -ExecutionPolicy Bypass -File scripts/run_local_windows.ps1",
    "dev": "vite --host 127.0.0.1 --port 5173",
    "dev:api": "node --watch server.js",
    "build": "vite build",
    "index:knowledge": "node scripts/index_knowledge.js",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "test": "node --test test/**/*.test.js",
    "check": "npm test && npm run build",
    "backup": "bash scripts/backup_data.sh",
    "restore": "bash scripts/restore_data.sh",
    "validate:tickets": "node scripts/validate_tickets.js",
    "archive:tickets": "node scripts/archive_tickets.js"
  },
  "dependencies": {
    "@react-three/drei": "10.7.7",
    "@react-three/fiber": "9.6.1",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "framer-motion": "12.40.0",
    "lucide-react": "1.17.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "10.1.0",
    "remark-gfm": "4.0.1",
    "three": "0.184.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.0",
    "@vitejs/plugin-react": "6.0.2",
    "autoprefixer": "10.5.0",
    "postcss": "8.5.15",
    "tailwindcss": "4.3.0",
    "vite": "8.0.16"
  }
}
