NODE_ENV=production
ADMIN_AUTH=<admin-user>:<long-random-password>
PORT=3000

# Ollama runtime
OLLAMA_BASE_URL=http://127.0.0.1:11434
LLM_MODEL=gemma4:e4b-it-qat
LLM_TIMEOUT_MS=60000

# Optional Google Sheet webhooks. Leave empty to save locally only.
GOOGLE_SHEET_WEBHOOK_URL=
ELECTRICITY_BILL_WEBHOOK_URL=

# Request body and rate limits
JSON_BODY_LIMIT_MB=40
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_GENERAL_MAX=120
RATE_LIMIT_CHAT_MAX=30
RATE_LIMIT_UPLOAD_MAX=10
RATE_LIMIT_TICKET_MAX=30

# RAG prompt safety limits
RAG_MAX_DOCS=4
RAG_MAX_CHARS_PER_DOC=1600
RAG_MAX_TOTAL_CONTEXT_CHARS=6000

# OCR through Ollama
TYPHOON_OCR_MODEL=scb10x/typhoon-ocr1.5-3b
TYPHOON_OCR_MAX_PDF_PAGES=3
TYPHOON_OCR_MAX_UPLOAD_MB=24
