{
  "name": "ai-ticket-desk",
  "version": "1.0.0",
  "description": "Lightweight IT ticket intake desk powered by Ollama vision, OCR, and reasoning models.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5173",
    "dev:api": "node --watch server.js",
    "build": "vite build",
    "start": "node server.js",
    "backup": "node scripts/backup.js",
    "restore": "node scripts/restore.js",
    "test": "node --test test/**/*.test.js",
    "check": "npm test && npm run build"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "multer": "^2.1.1",
    "nanoid": "^5.0.9",
    "sharp": "^0.33.5",
    "vite": "^6.0.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {}
}
