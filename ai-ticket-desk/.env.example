NODE_ENV=development
PORT=3000
APP_NAME=AI Ticket Desk

OLLAMA_BASE_URL=http://127.0.0.1:11434
VISION_MODEL=gemma3:12b
OCR_MODEL=scb10x/typhoon-ocr1.5-3b
REASONING_MODEL=gemma3:12b

AI_TEMPERATURE=0.1
AI_TOP_P=0.9
AI_NUM_CTX=8192
AI_NUM_PREDICT=1200
AI_TIMEOUT_MS=120000
AI_DEBUG=true

MAX_UPLOAD_MB=24
PDF_MAX_PAGES=3

ADMIN_AUTH=admin:change-me
RATE_LIMIT_ANALYZE_PER_15M=20
RATE_LIMIT_SAVE_PER_15M=60

DATA_DIR=data
ATTACHMENT_DIR=data/attachments
DB_PATH=data/app.db
