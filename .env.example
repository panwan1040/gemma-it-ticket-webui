# Local Gemma llama.cpp server
LLM_BASE_URL=http://127.0.0.1:18080/v1
LLM_MODEL=gemma4-e4b-qat
LLM_TIMEOUT_MS=25000
PORT=3000

# Public app branding, safe to expose to browser
APP_NAME=Local AI Helpdesk
APP_TAGLINE=AI-assisted ticket intake for internal support teams
APP_DESCRIPTION=Collect issue details, draft tickets, and save them to your support workflow.

# Optional: Google Apps Script Web App URL for appending rows to Google Sheets
GOOGLE_SHEET_WEBHOOK_URL=

# Admin page basic auth for /admin and /api/admin/*
# Development can run without this and will use a clearly marked dev-only fallback.
# Production refuses to start if ADMIN_AUTH is missing or set to an unsafe default.
# Example: ADMIN_AUTH=admin:use-a-long-random-password
ADMIN_AUTH=

# Optional Typhoon OCR worker for admin document ingestion
# Install: scripts/install_typhoon_ocr.sh
TYPHOON_OCR_BASE_URL=http://127.0.0.1:11434
TYPHOON_OCR_MODEL=scb10x/typhoon-ocr1.5-3b
TYPHOON_OCR_MAX_PDF_PAGES=3
TYPHOON_OCR_MAX_UPLOAD_MB=24

# Request size and rate limits
JSON_BODY_LIMIT_MB=40
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_GENERAL_MAX=120
RATE_LIMIT_CHAT_MAX=30
RATE_LIMIT_UPLOAD_MAX=10
RATE_LIMIT_TICKET_MAX=30
RAG_MAX_DOCS=4
RAG_MAX_CHARS_PER_DOC=1600
RAG_MAX_TOTAL_CONTEXT_CHARS=6000
